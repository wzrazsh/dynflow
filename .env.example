# Provider API keys. Resolution priority (highest first):
#   OPENCODE_API_KEY     -> OpenCode provider
#   OPENAI_API_KEY       -> OpenAI provider
#   MINIMAX_CN_API_KEY   -> MiniMax China provider (`minimax` in the UI auto-maps to `minimax-cn` in pi)
#   MINIMAX_API_KEY      -> MiniMax International provider (fallback for `minimax`)
#   ANTHROPIC_API_KEY    -> Anthropic provider
OPENCODE_API_KEY=your_opencode_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
MINIMAX_CN_API_KEY=your_minimax_cn_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here

# MiniMax Anthropic-compatible endpoint (used by pi's minimax-cn provider)
# The UI presents "minimax"; the runner maps it to pi's `minimax-cn` (China region)
# which uses this base URL internally:
#   https://api.minimaxi.com/anthropic/v1/messages
MINIMAX_API_HOST=https://api.minimaxi.com

# Provider base URL override (used by opencode / openai / minimax proxies)
OPENAI_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=mimo-v2.5-free

# Optional - server config
PORT=13001
# Server host (default: 127.0.0.1)
HOST=127.0.0.1
DB_PATH=./data/workflows.db
